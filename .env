DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=videogo_user
HTTP_ADDR=:8081

CMS_PUBLIC_BASE_URL=http://localhost:8000
WORKER_ENABLED=1
WEBHOOK_SECRET=123456

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
# CORS: để trống = cho phép mọi origin (dev). Production: CSV origins
# CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# Security headers: HSTS chỉ bật khi API chỉ phục vụ qua HTTPS (TLS termination tại proxy hoặc trực tiếp).
# Không bật trên http://localhost — trình duyệt có thể ép HTTPS cho host đó.
# ENABLE_HSTS=0
# HSTS_MAX_AGE=31536000

# Giới hạn POST comment/like theo IP (cửa sổ phút). Mặc định trong code: 45 req / 1 phút.
COMMENT_WRITE_RATE_MAX=45
COMMENT_WRITE_RATE_WINDOW_MINUTES=1


# Redis (tùy chọn): hàng đợi fan-out / push. Để trống = fan-out chạy trong process khi nhận webhook.
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=2

# Push (FCM/APNs stub): cần Redis + PUSH_WORKER_ENABLED=1; client đăng ký token qua POST /v1/me/devices
PUSH_WORKER_ENABLED=1
PUSH_RATE_PER_SECOND=50